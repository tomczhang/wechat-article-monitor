# 调试微信代理请求 (仅开发环境(development)支持)
NUXT_DEBUG_MP_REQUEST=false

# AG-Grid 企业版授权
NUXT_AGGRID_LICENSE=

# KV绑定(本地/docker)
NITRO_KV_DRIVER=fs
NITRO_KV_BASE=.data/kv

# KV绑定(cloudflare)
#NITRO_KV_DRIVER=cloudflare-kv-binding

DEBUG_KEY=

# === Credential 抓包服务（mitmproxy）===
# 端口 (默认 65000)
CREDENTIAL_MITM_PORT=65000

# mitmproxy 监听地址：本地用 127.0.0.1（默认），VPS 远程模式用 0.0.0.0
# 当设为非 loopback 时，MITM_PROXY_AUTH 必须填写，否则容器启动会拒绝 (FATAL)
MITM_LISTEN_HOST=127.0.0.1

# 远程模式必填：mitm 入站身份验证，格式 user:pass
# 手机端代理软件（Surfboard / NekoBox）填这套账号密码
MITM_PROXY_AUTH=

# 远程模式下用于 Dashboard 提示用户配置的 mitm 公网入口（不带 http://，不带端口）
# 通常 = PUBLIC_DOMAIN
CREDENTIAL_PUBLIC_HOST=

# === 部署：Caddy + Let's Encrypt ===
# 公网域名（必填于 docker compose 远程部署）；未填则跳过 Caddy，仅启 Nuxt:3000
PUBLIC_DOMAIN=

# Let's Encrypt 通知邮箱（证书将到期时收提醒）
# 留空时 entrypoint 自动用 admin@${PUBLIC_DOMAIN}
CADDY_ACME_EMAIL=
